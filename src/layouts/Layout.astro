---
interface Props {
	title: string;
	description: string;
	lang?: string;
	keywords?: string;
}

import { GA_MEASUREMENT_ID, LANGUAGE_CODES } from '../config';

const { title, description, lang = "en", keywords } = Astro.props;

const supportedLangs = LANGUAGE_CODES;
const baseUrl = "https://uxbooks.in";
const defaultKeywords = "UX design books, UI design books, User experience design books, User interface design books, Interaction design books, UI/UX design ebooks, UX design books for beginners, UX design textbook, Foundational UX books, UX research books, Amazon India, Umar Shareef";
---

<!DOCTYPE html>
<html lang={lang} prefix="og: http://ogp.me/ns#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords || defaultKeywords} />
    <meta name="msvalidate.01" content="DAC8906374E8211CD526FC5E4C3920F0" />
    <meta http-equiv="Content-Security-Policy" content={`default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://m.media-amazon.com https://c.amazon-adsystem.com https://www.clarity.ms; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://*.clarity.ms;`} />
    <link rel="canonical" href={Astro.url} />
    
    {supportedLangs.map((l) => {
      // Correctly handle subpaths for hreflang
      // If we are at /category/ux-design, and l is 'ta', we want /ta/category/ux-design
      // Astro.url.pathname will have the current path (e.g., /category/ux-design or /ta/category/ux-design)
      
      const currentPath = Astro.url.pathname;
      const pathSegments = currentPath.split('/').filter(Boolean);
      
      // Remove language prefix if present
      if (supportedLangs.includes(pathSegments[0]) && pathSegments[0] !== 'en') {
        pathSegments.shift();
      }
      
      const subPath = pathSegments.join('/');
      const finalPath = l === 'en' 
        ? (subPath ? `/${subPath}` : '/') 
        : `/${l}/${subPath}`;

      return (
        <link 
          rel="alternate" 
          hreflang={l} 
          href={new URL(finalPath, baseUrl)} 
        />
      );
    })}
    <link rel="alternate" hreflang="x-default" href={new URL('/', baseUrl)} />
    
    <!-- Google tag (gtag.js) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>
    
    <!-- Clarity -->
    <script type="text/javascript" is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
        t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "pm5p5t4rax");
    </script>
    
    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang} />
    <meta property="og:site_name" content="UI/UX Design Bookshelf" />
    <meta property="og:image" content={new URL("/og-image.png", Astro.url)} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL("/og-image.png", Astro.url)} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..800;1,14..32,300..800&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
  </body>
</html>

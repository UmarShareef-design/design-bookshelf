---
import Layout from '../layouts/Layout.astro';
import MainApp from '../components/MainApp.jsx';
import '../index.css';
import { NON_DEFAULT_LANG_CODES } from '../config';
import { categories, slugifyCategory, categoryFromSlug } from '../utils/books';

export async function getStaticPaths() {
  const langs = NON_DEFAULT_LANG_CODES;

  // Define URLs as slugs, passing categories via props so the page body
  // can reuse them without a second dynamic import of books.json.
  const baseProps = { categories };

  const paths = [
    { params: { slug: undefined }, props: baseProps },
    { params: { slug: 'about' }, props: baseProps },
    { params: { slug: 'select-language' }, props: baseProps },
  ];

  // English Categories
  for (const cat of categories) {
    const slugCat = slugifyCategory(cat);
    paths.push({ params: { slug: `category/${slugCat}` }, props: baseProps });
  }

  // Language paths
  for (const lang of langs) {
    paths.push({ params: { slug: lang }, props: baseProps });
    paths.push({ params: { slug: `${lang}/about` }, props: baseProps });
    paths.push({ params: { slug: `${lang}/select-language` }, props: baseProps });
    for (const cat of categories) {
      const slugCat = slugifyCategory(cat);
      paths.push({ params: { slug: `${lang}/category/${slugCat}` }, props: baseProps });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { categories } = Astro.props;
const url = Astro.url.pathname.endsWith('/')
    ? Astro.url.pathname
    : Astro.url.pathname + '/';

let currentLang = 'en';
let rest = slug || '';

const langs = NON_DEFAULT_LANG_CODES;
const parts = rest.split('/');
if (parts.length > 0 && langs.includes(parts[0])) {
  currentLang = parts[0];
  rest = parts.slice(1).join('/');
}

const translations = (await import(`../i18n/locales/${currentLang}.json`)).default;

let title = translations.title;
let description = translations.subtitle;
let keywords = "";
let category = "";
let noindex = false;

if (rest === 'select-language') {
    noindex = true;
    title = translations.common.select_language + " | " + translations.title;
} else if (rest === 'about') {
    title = translations.about.title + " | " + translations.title;
    description = translations.about.p1;
} else if (rest.startsWith('category/')) {
    const slugCat = rest.replace('category/', '');
    const categoryName = categoryFromSlug(slugCat);
    if (categoryName && translations.meta[categoryName]) {
        category = categoryName;
        title = translations.meta[categoryName].title;
        description = translations.meta[categoryName].description;
        keywords = `${categoryName} books, best ${categoryName} books, ${categoryName} reference, design books, ${currentLang} ${categoryName}`;
    }
}
---

<Layout 
  title={title} 
  description={description} 
  lang={currentLang} 
  keywords={keywords}
  category={category}
  noindex={noindex}
>
  <script is:inline define:vars={{ initialI18nStore: translations, initialLanguage: currentLang }}>
    window.initialI18nStore = initialI18nStore;
    window.initialLanguage = initialLanguage;
  </script>
  <MainApp url={url} initialResources={translations} lang={currentLang} client:load />
</Layout>

